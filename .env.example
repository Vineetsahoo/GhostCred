# GhostCred environment variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Core ──────────────────────────────────────────────────────────────────────

# Salt used to fingerprint detected secrets (salted SHA-256).
# Generate a strong value with: python -c "import secrets; print(secrets.token_hex(32))"
# If unset, a random salt is generated per run (findings won't be comparable across runs).
GHOSTCRED_SALT=change-me-to-a-random-hex-string

# Set to 1 to enable auto-revocation without passing --revoke-live on every CLI call.
# Default: 0 (disabled — revocation is destructive and requires explicit opt-in)
GHOSTCRED_AUTO_REVOKE=0

# ── Revocation — provider admin keys ─────────────────────────────────────────
# These are GhostCred's OWN credentials used to call provider revocation APIs.
# They are NOT the leaked secrets being revoked.

# GitHub: a GitHub App private key or personal token with delete:token scope.
# Used to revoke installation tokens via DELETE /installation/token.
GHOSTCRED_GITHUB_TOKEN=

# OpenAI: an organisation admin API key (not a project key).
# Used to look up and delete a leaked key via the admin API.
GHOSTCRED_OPENAI_ADMIN_KEY=

# Anthropic: a Console admin API key.
# Used to look up and delete a leaked key via the Console API.
GHOSTCRED_ANTHROPIC_ADMIN_KEY=

# ── Metrics ───────────────────────────────────────────────────────────────────

# Port for the Prometheus /metrics endpoint (default: 9308).
GHOSTCRED_METRICS_PORT=9308

# ── CI / Lineage ──────────────────────────────────────────────────────────────

# Local directory where `gh run view --log` output is written before a scan.
# Used by the lineage tracker to check if a secret leaked into CI logs.
GHOSTCRED_CI_LOG_DIR=.ghostcred/ci-logs

# ── Docker stack (docker-compose) ─────────────────────────────────────────────

# Password for the Grafana admin user (default: ghostcred — change in production).
GRAFANA_PASSWORD=ghostcred
