# Copy to .ghostcred.yml and adjust for your repo.

min_confidence: 0.6
include_ai_toolchain: true
include_global_configs: false   # true only for local `ghostcred scan` on a dev machine
auto_revoke: false
dry_run_revocations: true
metrics_port: 9308

ignore_paths:
  - "tests/fixtures/**"
  - "docs/**"

# Populated by CI after `gh run view --log` — used by the lineage tracker.
ci_log_dir: ".ghostcred/ci-logs"

# Optional: image tags to inspect with `docker history` for lineage tracking.
docker_image_tags: []
